//@version=5
indicator("XAUUSD — SMC + EMA200 + VWAP (H1/M15/M5)", overlay=true, max_bars_back=500)

h1_close  = request.security(syminfo.tickerid, "60", close)
h1_high   = request.security(syminfo.tickerid, "60", high)
h1_low    = request.security(syminfo.tickerid, "60", low)
h1_open   = request.security(syminfo.tickerid, "60", open)
h1_ema200 = request.security(syminfo.tickerid, "60", ta.ema(close, 200))
h1_cumPV  = request.security(syminfo.tickerid, "60", ta.cum(hlc3 * volume))
h1_cumVol = request.security(syminfo.tickerid, "60", ta.cum(volume))
h1_vwap   = h1_cumPV / h1_cumVol
h1_aboveEMA200 = h1_close > h1_ema200
h1_aboveVWAP   = h1_close > h1_vwap

m15_close  = request.security(syminfo.tickerid, "15", close)
m15_ema200 = request.security(syminfo.tickerid, "15", ta.ema(close, 200))
m15_cumPV  = request.security(syminfo.tickerid, "15", ta.cum(hlc3 * volume))
m15_cumVol = request.security(syminfo.tickerid, "15", ta.cum(volume))
m15_vwap   = m15_cumPV / m15_cumVol
m15_aboveEMA200 = m15_close > m15_ema200
m15_aboveVWAP   = m15_close > m15_vwap

m5_ema9   = ta.ema(close, 9)
m5_ema21  = ta.ema(close, 21)
m5_ema200 = ta.ema(close, 200)
m5_cumPV  = ta.cum(hlc3 * volume)
m5_cumVol = ta.cum(volume)
m5_vwap   = m5_cumPV / m5_cumVol
m5_rsi    = ta.rsi(close, 14)
[m5_macd, m5_sig, m5_hist] = ta.macd(close, 12, 26, 9)
atr = ta.atr(14)

m5_aboveVWAP      = close > m5_vwap
m5_vwapBullBounce = low[1] < m5_vwap  and close > m5_vwap
m5_vwapBearBounce = high[1] > m5_vwap and close < m5_vwap

m15_bullOB = m15_close[1] < request.security(syminfo.tickerid, "15", open)[1] and m15_close > request.security(syminfo.tickerid, "15", high)[1]
m15_bearOB = m15_close[1] > request.security(syminfo.tickerid, "15", open)[1] and m15_close < request.security(syminfo.tickerid, "15", low)[1]
m15_bullFVG = request.security(syminfo.tickerid, "15", low > high[2])
m15_bearFVG = request.security(syminfo.tickerid, "15", high < low[2])
m15_rHigh   = request.security(syminfo.tickerid, "15", ta.highest(high, 10)[1])
m15_rLow    = request.security(syminfo.tickerid, "15", ta.lowest(low,   10)[1])
m15_sweepLow  = m15_close[1] < m15_rLow  and m15_close > m15_rLow
m15_sweepHigh = m15_close[1] > m15_rHigh and m15_close < m15_rHigh

m5_rHigh     = ta.highest(high, 8)[1]
m5_rLow      = ta.lowest(low,   8)[1]
m5_sweepLow  = low  < m5_rLow  and close > m5_rLow
m5_sweepHigh = high > m5_rHigh and close < m5_rHigh

var bool m5_bull = false
var bool m5_bear = false
m5_swHigh = ta.pivothigh(high, 3, 3)
m5_swLow  = ta.pivotlow(low,  3, 3)
var float m5_lastHigh = na
var float m5_lastLow  = na
if not na(m5_swHigh)
    m5_lastHigh := m5_swHigh
if not na(m5_swLow)
    m5_lastLow := m5_swLow
m5_bosUp   = not na(m5_lastHigh) and close > m5_lastHigh
m5_bosDown = not na(m5_lastLow)  and close < m5_lastLow
m5_chochBull = m5_bear and m5_bosUp
m5_chochBear = m5_bull and m5_bosDown
if m5_bosUp
    m5_bull := true
    m5_bear := false
if m5_bosDown
    m5_bear := true
    m5_bull := false

h1_discount = h1_close < (h1_close + h1_close) / 2
h1_premium  = h1_close > (h1_close + h1_close) / 2

buySignal =
     h1_aboveEMA200 and
     h1_aboveVWAP and
     m15_aboveEMA200 and
     (m15_aboveVWAP or m15_sweepLow) and
     (m15_bullOB or m15_bullFVG or m15_sweepLow) and
     (m5_chochBull or m5_sweepLow) and
     close > m5_ema200 and
     (m5_aboveVWAP or m5_vwapBullBounce) and
     m5_ema9 > m5_ema21 and
     m5_rsi > 45 and m5_rsi < 72 and
     m5_hist > 0

sellSignal =
     not h1_aboveEMA200 and
     not h1_aboveVWAP and
     not m15_aboveEMA200 and
     (not m15_aboveVWAP or m15_sweepHigh) and
     (m15_bearOB or m15_bearFVG or m15_sweepHigh) and
     (m5_chochBear or m5_sweepHigh) and
     close < m5_ema200 and
     (not m5_aboveVWAP or m5_vwapBearBounce) and
     m5_ema9 < m5_ema21 and
     m5_rsi < 55 and m5_rsi > 28 and
     m5_hist < 0

slBuy  = close - atr * 1.5
tpBuy  = close + atr * 3.0
slSell = close + atr * 1.5
tpSell = close - atr * 3.0

plot(m5_ema200, "EMA200 M5", color.new(color.orange, 0),  linewidth=2)
plot(m5_ema9,   "EMA9",      color.new(color.green,  50), linewidth=1)
plot(m5_ema21,  "EMA21",     color.new(color.red,    50), linewidth=1)
plot(m5_vwap,   "VWAP M5",   color.new(color.blue,   0),  linewidth=2)
plot(h1_vwap,   "VWAP H1",   color.new(color.blue,   50), linewidth=1)
plot(h1_ema200, "EMA200 H1", color.new(color.orange, 50), linewidth=1)

plotshape(buySignal,  "BUY",  shape.triangleup,   location.belowbar, color.lime, size=size.normal)
plotshape(sellSignal, "SELL", shape.triangledown,  location.abovebar, color.red,  size=size.normal)

bgcolor(h1_aboveEMA200 and h1_aboveVWAP ? color.new(color.green, 97) :
        not h1_aboveEMA200 and not h1_aboveVWAP ? color.new(color.red, 97) : na)

buyMsg = '{"direction":"BUY","strategy":"H1-M15-M5-EMA200-VWAP","price":' + str.tostring(close) + ',"h1_aboveEMA200":' + str.tostring(h1_aboveEMA200) + ',"h1_aboveVWAP":' + str.tostring(h1_aboveVWAP) + ',"h1_ema200":' + str.tostring(math.round(h1_ema200,2)) + ',"h1_vwap":' + str.tostring(math.round(h1_vwap,2)) + ',"m15_aboveEMA200":' + str.tostring(m15_aboveEMA200) + ',"m15_vwap_ok":' + str.tostring(m15_aboveVWAP) + ',"m15_ema200":' + str.tostring(math.round(m15_ema200,2)) + ',"m15_vwap":' + str.tostring(math.round(m15_vwap,2)) + ',"m15_ob":' + str.tostring(m15_bullOB) + ',"m15_fvg":' + str.tostring(m15_bullFVG) + ',"m15_sweep":' + str.tostring(m15_sweepLow) + ',"m5_aboveEMA200":' + str.tostring(close > m5_ema200) + ',"m5_vwap_ok":' + str.tostring(m5_aboveVWAP) + ',"m5_ema200":' + str.tostring(math.round(m5_ema200,2)) + ',"m5_vwap":' + str.tostring(math.round(m5_vwap,2)) + ',"m5_choch":' + str.tostring(m5_chochBull) + ',"m5_sweep":' + str.tostring(m5_sweepLow) + ',"ema_bull":' + str.tostring(m5_ema9 > m5_ema21) + ',"rsi":' + str.tostring(math.round(m5_rsi,1)) + ',"macd_bull":' + str.tostring(m5_hist > 0) + ',"sl":' + str.tostring(math.round(slBuy,2)) + ',"tp":' + str.tostring(math.round(tpBuy,2)) + ',"atr":' + str.tostring(math.round(atr,2)) + '}'

sellMsg = '{"direction":"SELL","strategy":"H1-M15-M5-EMA200-VWAP","price":' + str.tostring(close) + ',"h1_aboveEMA200":' + str.tostring(h1_aboveEMA200) + ',"h1_aboveVWAP":' + str.tostring(h1_aboveVWAP) + ',"h1_ema200":' + str.tostring(math.round(h1_ema200,2)) + ',"h1_vwap":' + str.tostring(math.round(h1_vwap,2)) + ',"m15_aboveEMA200":' + str.tostring(m15_aboveEMA200) + ',"m15_vwap_ok":' + str.tostring(not m15_aboveVWAP) + ',"m15_ema200":' + str.tostring(math.round(m15_ema200,2)) + ',"m15_vwap":' + str.tostring(math.round(m15_vwap,2)) + ',"m15_ob":' + str.tostring(m15_bearOB) + ',"m15_fvg":' + str.tostring(m15_bearFVG) + ',"m15_sweep":' + str.tostring(m15_sweepHigh) + ',"m5_aboveEMA200":' + str.tostring(close < m5_ema200) + ',"m5_vwap_ok":' + str.tostring(not m5_aboveVWAP) + ',"m5_ema200":' + str.tostring(math.round(m5_ema200,2)) + ',"m5_vwap":' + str.tostring(math.round(m5_vwap,2)) + ',"m5_choch":' + str.tostring(m5_chochBear) + ',"m5_sweep":' + str.tostring(m5_sweepHigh) + ',"ema_bear":' + str.tostring(m5_ema9 < m5_ema21) + ',"rsi":' + str.tostring(math.round(m5_rsi,1)) + ',"macd_bear":' + str.tostring(m5_hist < 0) + ',"sl":' + str.tostring(math.round(slSell,2)) + ',"tp":' + str.tostring(math.round(tpSell,2)) + ',"atr":' + str.tostring(math.round(atr,2)) + '}'

alertcondition(buySignal,  "BUY Signal",  buyMsg)
alertcondition(sellSignal, "SELL Signal", sellMsg)
