# ─────────────────────────────────────────
# XAUUSD Signal Bot — Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit .env to git
# ─────────────────────────────────────────

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=987654321

# Webhook server port (for TradingView → your server)
WEBHOOK_PORT=3000

# Signal thresholds
CONFIDENCE_THRESHOLD=70        # minimum % to send alert
COOLDOWN_MINUTES=30            # minimum minutes between same-direction signals

# Trading session (Bangkok UTC+7): London+NY overlap = 14:00-22:00
SESSION_START_HOUR=14
SESSION_END_HOUR=22

# Model selection (cost optimisation)
# Routine news checks  → haiku  (cheap)
# Signal validation    → sonnet (accurate)
MODEL_CHEAP=claude-haiku-4-5-20251001
MODEL_SMART=claude-sonnet-4-6
